{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Life-Log",
  "version": "0.1.0",
  "identifier": "com.crd.life-log",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Life-Log",
        "url": "index.html#/",
        "width": 720,
        "height": 540,
        "resizable": true,
        "visible": true,
        "center": true
      },
      {
        "label": "checkin",
        "title": "Life-Log · 打卡",
        "url": "index.html#/checkin",
        "width": 360,
        "height": 280,
        "resizable": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "Life-Log"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
